# BrowerAI Studio Labs local environment example
# Copy values into your shell or a local untracked .env file.
# Do not commit real secrets to the repository.

# Optional n8n API auth used by the local managed runtime.
N8N_API_KEY=

# Example provider API environment variables for Provider Hub profiles.
BROWSERAI_PROVIDER_API_KEY=
BROWSERAI_PROVIDER_ALT_API_KEY=
